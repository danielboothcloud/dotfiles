#!/bin/zsh
unalias la 2>/dev/null
alias kb="kubectl"
alias istio="istioctl"
alias mk="minikube"
alias dc="docker-compose"
alias tf="terraform"
alias kc="click"
alias 1p="op"
alias vi="nvim"
alias pm="pnpm"
alias px="pnpx"
alias vpn="viscosity-cli"
alias redis="redis_tui"
alias tpe="telepresence"
alias docker="podman"
alias gci="cz"
alias tg="terragrunt"
alias tun="sshuttle-aws"
alias dotfiles="chezmoi"
alias ll="eza --color=always --long --git --icons=always --no-user"
alias ls="eza --color=always --long --git --no-filesize --icons=always --no-time --no-user --no-permissions"
alias cat="bat --paging never --style=numbers,changes --theme base16"
alias less="bat --paging always --style=numbers,changes --theme base16"
alias top="btop"
alias todo="togo"
alias post="posting"
alias fvi='selected=$(fzf -m --preview="bat --color=always {}") && [[ -n $selected ]] && nvim $selected'
alias ded='selected=$(chezmoi managed -i files | fzf) && chezmoi edit "$HOME/$selected" && chezmoi apply $HOME/$selected -v --no-pager'
