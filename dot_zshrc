# Load environment variables from .env
if [ -f ~/.env ]; then
    source ~/.env
fi

# Load aliases
if [ -f ~/.aliases ]; then
    source ~/.aliases
fi

if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

[[ "$TERM" == "ghostty" || "$TERM" == "xterm-ghostty" ]] && alias ssh='TERM=xterm-256color ssh'

if [[ -n "$SSH_CONNECTION" ]]; then
    if infocmp ghostty &>/dev/null; then
        export TERM=ghostty
    else
        export TERM=xterm-256color
    fi
fi

typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

export PATH="/opt/homebrew/bin:$HOME/bin:$HOME/.local/bin:/usr/local/bin:${KREW_ROOT:-$HOME/.krew}/bin:$HOME/go/bin:$PATH"

export ZSH_DISABLE_COMPFIX=true

autoload -Uz compinit
compinit

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
  git
)

ccinit() {
  claude mcp add --transport http context7 https://mcp.context7.com/mcp
  claude mcp add sequential-thinking npx @modelcontextprotocol/server-sequential-thinking
  claude mcp add endor -- endor mcp --allow-net # mcp for endor (development sandboxes)
  claude mcp add playwright npx @playwright/mcp@latest # mcp for playwright (testing)
  claude mcp add svelte-docs npx mcp-svelte-docs # mcp for svelte 5
  claude mcp add tailwind-v4-docs node /Users/danielbooth/projects/home/tailwind-mcp/build/index.js  # mcp for tailwind v4
  claude mcp add go-docs /Users/danielbooth/go/bin/godoc-mcp # mcp for golang documentation
  claude mcp add serena -- uvx --from git+https://github.com/oraios/serena serena start-mcp-server --context ide-assistant --project $(pwd)
  uvx --from git+https://github.com/oraios/serena serena project index
  # mcp for terraform
  # mcp for atmos
}

kube() {
  if [[ -z "$1" ]]; then
    if [[ -n "$KUBECONFIG" ]]; then
      atuin dotfiles var delete KUBECONFIG &>/dev/null
      unset KUBECONFIG
      echo "KUBECONFIG unset"
    else
      export KUBECONFIG="/Users/$(whoami)/.kube/config"
      atuin dotfiles var set KUBECONFIG '/Users/danielbooth/.kube/config' &>/dev/null
      echo "Switched to $(kubectl config current-context) Kubernetes context"
    fi
  else
    export KUBECONFIG="/Users/$(whoami)/.kube/$1/config"
    atuin dotfiles var set KUBECONFIG '/Users/danielbooth/.kube/config' &>/dev/null
    echo "Switched to Kubernetes context: $1"
  fi
}

source <(kubectl completion zsh)
source $ZSH/oh-my-zsh.sh
source ~/.config/zsh/functions/clones.zsh

# pnpm
export PNPM_HOME="/Users/danielbooth/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# unalias 
unalias gup 2>/dev/null

PROMPT='$(kube_ps1)'$PROMPT

source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
FZF_CTRL_R_COMMAND= source <(fzf --zsh)

eval "$(pyenv init --path)"
eval "$(direnv hook zsh)"
eval "$(zoxide init zsh --cmd cd)"
eval "$(atuin init zsh)"

# goenv initialization
export GOENV_ROOT="$HOME/.goenv"
export PATH="$GOENV_ROOT/bin:$PATH"
eval "$(goenv init -)"

# Set GOBIN to a static location for go install binaries
export GOBIN="$HOME/go/bin"
