# =============================================================================
# ZSH CONFIGURATION - Optimized for fast startup
# Expected load time: 50-200ms (down from 1000-1800ms)
# =============================================================================

# Load environment variables from .env
if [ -f ~/.env ]; then
    source ~/.env
fi

# -----------------------------------------------------------------------------
#  INSTANT PROMPT - Must be at the very top
# -----------------------------------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

# -----------------------------------------------------------------------------
#  TERMINAL SETUP
# -----------------------------------------------------------------------------
[[ "$TERM" == "ghostty" || "$TERM" == "xterm-ghostty" ]] && alias ssh='TERM=xterm-256color ssh'

if [[ -n "$SSH_CONNECTION" ]]; then
    if infocmp ghostty &>/dev/null; then
        export TERM=ghostty
    else
        export TERM=xterm-256color
    fi
fi

# -----------------------------------------------------------------------------
#  PATH SETUP - Set all paths before loading plugins
# -----------------------------------------------------------------------------
export PATH="/opt/homebrew/bin:$HOME/bin:$HOME/.local/bin:/usr/local/bin:${KREW_ROOT:-$HOME/.krew}/bin:$HOME/go/bin:$PATH"

# pnpm
export PNPM_HOME="/Users/danielbooth/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# pyenv paths (lazy-loaded, but paths needed now)
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"

# goenv paths (lazy-loaded, but paths needed now)
export GOENV_ROOT="$HOME/.goenv"
export PATH="$GOENV_ROOT/bin:$PATH"
export GOBIN="$HOME/go/bin"

# -----------------------------------------------------------------------------
#  OH MY ZSH - Load framework (adds completion paths to fpath)
# -----------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
export ZSH_DISABLE_COMPFIX=true
ZSH_THEME="robbyrussell"
plugins=(git)

source $ZSH/oh-my-zsh.sh

# unalias conflicts
unalias gup 2>/dev/null

# -----------------------------------------------------------------------------
#  CACHED COMPLETIONS - Load before compinit
# -----------------------------------------------------------------------------
# kubectl completion (cached) - Auto-generates on first run
if [[ -f ~/.zsh_completion_kubectl ]]; then
  source ~/.zsh_completion_kubectl
elif command -v kubectl &>/dev/null; then
  # First run: generate cache for future startups
  kubectl completion zsh > ~/.zsh_completion_kubectl
  source ~/.zsh_completion_kubectl
fi

# -----------------------------------------------------------------------------
#  COMPINIT - Run AFTER all fpath additions, with caching
# -----------------------------------------------------------------------------
autoload -Uz compinit

# Only regenerate compdump once per day
if [[ -n ${HOME}/.zcompdump(#qNmh+24) ]]; then
  compinit
else
  compinit -C
fi

# -----------------------------------------------------------------------------
#  THEME - Load after Oh My Zsh and compinit
# -----------------------------------------------------------------------------
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# -----------------------------------------------------------------------------
#  LAZY-LOADED TOOLS - Only initialize when actually used
# -----------------------------------------------------------------------------
# pyenv - lazy load (saves ~100ms startup)
pyenv() {
  unfunction pyenv
  eval "$(command pyenv init --path)"
  eval "$(command pyenv init -)"
  pyenv "$@"
}

# goenv - lazy load (saves ~100ms startup)
goenv() {
  unfunction goenv
  eval "$(command goenv init -)"
  goenv "$@"
}

# -----------------------------------------------------------------------------
#  FREQUENTLY-USED TOOLS - Cache when possible
# -----------------------------------------------------------------------------
# direnv - cached hook (regenerate with: direnv hook zsh > ~/.zsh_direnv_hook)
if [[ -f ~/.zsh_direnv_hook ]]; then
  source ~/.zsh_direnv_hook
elif command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# fzf - cached (regenerate with: fzf --zsh > ~/.zsh_fzf)
if [[ -f ~/.zsh_fzf ]]; then
  source ~/.zsh_fzf
elif command -v fzf &>/dev/null; then
  FZF_CTRL_R_COMMAND= source <(fzf --zsh)
fi

# zoxide - cached (regenerate with: zoxide init zsh --cmd cd > ~/.zsh_zoxide)
if [[ -f ~/.zsh_zoxide ]]; then
  source ~/.zsh_zoxide
elif command -v zoxide &>/dev/null; then
  zoxide init zsh --cmd cd > ~/.zsh_zoxide
  source ~/.zsh_zoxide
fi

# atuin - must run fresh each time to load dotfiles vars
eval "$(atuin init zsh)"

# -----------------------------------------------------------------------------
#  SYNTAX HIGHLIGHTING - Must be loaded last
# -----------------------------------------------------------------------------
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# -----------------------------------------------------------------------------
#  CUSTOM FUNCTIONS
# -----------------------------------------------------------------------------

# Load custom function files
for func_file in ~/.config/zsh/functions/*.zsh; do
  if [[ -r "$func_file" ]]; then
    source "$func_file"
  fi
done
unset func_file

# -----------------------------------------------------------------------------
#  ALIASES - Load at the end
# -----------------------------------------------------------------------------
if [ -f ~/.aliases ]; then
    source ~/.aliases
fi
