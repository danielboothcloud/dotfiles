#!/bin/bash
# Update package lists from currently installed packages

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Updating package lists..."
echo ""

# Update Brewfile
echo "Updating Brewfile from installed Homebrew packages..."
if command -v brew &> /dev/null; then
    cd "$SCRIPT_DIR"
    brew bundle dump --force
    echo "✓ Brewfile updated"
else
    echo "✗ Homebrew not installed, skipping Brewfile"
fi

echo ""

# Update gup.conf
echo "Updating gup.conf from installed Go binaries..."
if command -v gup &> /dev/null; then
    cd "$SCRIPT_DIR"
    gup export -o > gup.conf
    echo "✓ gup.conf updated"
else
    echo "✗ gup not installed, skipping gup.conf"
fi

echo ""
echo "Package lists updated successfully!"
echo "Don't forget to commit the changes to git."
